    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP: Taxa de Requisições por URI",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by(uri, method) (rate(http_server_requests_milliseconds_count{exported_job=\"brewer\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}",
          "instant": false
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP: Latência P50 e P99 (ms)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
