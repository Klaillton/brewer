      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by(le, uri) (rate(http_server_requests_milliseconds_bucket{exported_job=\"brewer\"}[5m])))",
          "legendFormat": "P50 {{uri}}",
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus"
